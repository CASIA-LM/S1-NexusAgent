#!/usr/bin/env bash
# Auto-load project environment (requires direnv: https://direnv.net/)
#
# Usage:
#   1) Install direnv and hook it into your shell
#   2) In repo root, run: direnv allow
#
# This makes `import unknown_science...` work when running from repo root.
export PYTHONPATH="${PWD}${PYTHONPATH:+:${PYTHONPATH}}"

