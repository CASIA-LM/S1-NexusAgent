# S1-NexusAgent Environment Configuration
# Copy this file to .env and fill in your values:
#   cp .env.template .env
#
# Lines starting with # are comments and will be ignored.
# Variables marked [REQUIRED] must be set before running the agent.
# Variables marked [OPTIONAL] can be left empty to disable the feature.

# ==============================================================================
# PRIMARY LLM — DeepSeek (used for chat, planning, execution)
# ==============================================================================

# [REQUIRED] Your DeepSeek API key
DEEPSEEK_API_KEY=

# DeepSeek API endpoint (default shown; change for self-hosted or proxy)
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# DeepSeek model name
DEEPSEEK_V3_2_MODEL=deepseek-chat


# ==============================================================================
# EMBEDDING MODEL — used for tool retrieval
# ==============================================================================

# [REQUIRED] API key for the embedding model endpoint
EMBEDDING_API_KEY=

# Embedding model endpoint (OpenAI-compatible)
EMBEDDING_BASE_URL=https://api.openai.com/v1

# Embedding model name
EMBEDDING_MODEL=Qwen/Qwen3-Embedding-8B


# ==============================================================================
# CODE EXECUTION SANDBOX
# Default points to localhost; set to your remote sandbox server if needed.
# ==============================================================================

SANDBOX_URL=http://localhost:9001

# ==============================================================================
# VISION-LANGUAGE MODEL — for image description tool
# ==============================================================================

# [OPTIONAL] OpenAI-compatible VL model endpoint
VL_MODEL_URL=
VL_MODEL_NAME=Qwen/Qwen2.5-VL-72B-Instruct


# ==============================================================================
# OBSERVABILITY — Langfuse (https://langfuse.com)
# Leave empty to disable tracing entirely.
# Self-host: https://langfuse.com/docs/deployment/self-host
# ==============================================================================

LANGFUSE_SECRET_KEY=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_BASE_URL=https://cloud.langfuse.com

# ==============================================================================
# MATERIALS PROJECT — for material science tools (https://materialsproject.org)
# ==============================================================================

# [OPTIONAL] Materials Project API key
MP_API_KEY=


# ==============================================================================
# SELF-HOSTED AI SERVICES (optional — for advanced biology tools)
# ==============================================================================

# EVO2 — DNA generation model endpoint
EVO2_URL=

# ESM3 — protein structure/sequence generation endpoints
ESM3_SEQUENCE_URL=
ESM3_STRUCTURE_URL=

# Mass spectrometry analysis model endpoint
MASSSPEC_URL=

# Protein info service endpoints
PROTEIN_INFO_URL=
PROTEIN_URL=


# Log level: DEBUG | INFO | WARNING | ERROR (default: INFO)
LOGGER_LEVEL=INFO
